{
  "type": "object",
  "title": "UOL Connection",
  "required": ["server_type", "email", "#api_token"],
  "properties": {
    "server_type": {
      "type": "string",
      "title": "Server",
      "description": "Which UOL environment to connect to.",
      "enum": ["production", "sandbox", "demo"],
      "default": "production",
      "format": "select",
      "propertyOrder": 1
    },
    "customer_id": {
      "type": "string",
      "title": "Customer ID",
      "description": "Your UOL customer ID (the subdomain assigned by UOL). Required for Production and Sandbox; leave empty for Demo.",
      "propertyOrder": 2,
      "options": {
        "dependencies": {
          "server_type": ["production", "sandbox"]
        }
      }
    },
    "email": {
      "type": "string",
      "title": "Email",
      "description": "UOL login email (Basic-auth username).",
      "propertyOrder": 3
    },
    "#api_token": {
      "type": "string",
      "title": "API Token",
      "format": "password",
      "description": "Token from UOL Settings → API tokens. The account needs the 'REST API' permission.",
      "propertyOrder": 4
    },
    "test_connection": {
      "type": "button",
      "format": "test-connection",
      "propertyOrder": 5,
      "options": {
        "async": {
          "label": "Test Connection",
          "action": "testConnection"
        }
      }
    }
  }
}
